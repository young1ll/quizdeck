# 로컬 개발용 환경변수 예시 (이슈 #6 — better-auth).
# 실제 값은 .env.local(gitignore)에 두거나, 프로덕션은 k8s Secret 로 주입한다.
# 이 파일은 "어떤 키가 필요한가"만 담는다 — 실값을 적지 말 것.

# 세션·JWT 서명 키. 32자 이상 무작위: openssl rand -base64 32
BETTER_AUTH_SECRET=

# postgres 접속(better-auth 어댑터 + 마이그레이션).
# 로컬은 docker 임시 postgres 예시(포트 충돌 회피용 55432):
#   docker run -d --name quizdeck-pg -e POSTGRES_USER=quizdeck \
#     -e POSTGRES_PASSWORD=quizdeck -e POSTGRES_DB=quizdeck -p 55432:5432 postgres:16-alpine
DATABASE_URL=postgres://quizdeck:quizdeck@localhost:55432/quizdeck

# 절대 URL·trustedOrigins(CSRF) 기준.
# 로컬은 http://localhost:3000, 프로덕션은 https://myquizdeck.com
BETTER_AUTH_URL=http://localhost:3000
